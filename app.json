{
  "expo": {
    "name": "Synaps",
    "slug": "synaps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "synaps",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0F0A1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.synaps.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Synaps uses tracking to provide personalized content and improve your experience.",
        "NSCameraUsageDescription": "Synaps uses the camera to add images to your flashcards.",
        "NSPhotoLibraryUsageDescription": "Synaps accesses your photo library to add images to your flashcards.",
        "NSMicrophoneUsageDescription": "Synaps uses the microphone to record audio for your flashcards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A1E"
      },
      "package": "com.synaps.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#4361EE"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Synaps accesses your photo library to add images to flashcards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b36a308f-0b44-451f-8e3d-6d4ba28efa34"
      }
    },
    "owner": "mdikici"
  }
}
