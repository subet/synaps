{
  "expo": {
    "name": "Synaps",
    "slug": "synaps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "synaps",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4361EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.synaps.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Synaps uses the camera to add images to your flashcards.",
        "NSPhotoLibraryUsageDescription": "Synaps accesses your photo library to add images to your flashcards.",
        "NSMicrophoneUsageDescription": "Synaps uses the microphone to record audio for your flashcards."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4361EE"
      },
      "package": "com.synaps.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#4361EE"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Synaps accesses your photo library to add images to flashcards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
